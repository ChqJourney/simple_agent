{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-path",
    "dialog:default",
    {
      "identifier": "fs:default",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$HOME" },
        { "path": "$HOME/**" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/**" }
      ]
    }
  ]
}
