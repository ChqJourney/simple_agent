{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "work agent",
    "version": "0.1.0",
    "identifier": "photonee",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "work agent",
                "width": 1024,
                "height": 768,
                "minWidth": 800,
                "minHeight": 600,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": "default-src \u0027self\u0027; script-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; img-src \u0027self\u0027 data: blob:; connect-src \u0027self\u0027 http://127.0.0.1:8765 ws://127.0.0.1:8765",
            "devCsp": "default-src \u0027self\u0027; script-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; img-src \u0027self\u0027 data: blob:; connect-src \u0027self\u0027 http://127.0.0.1:8765 ws://127.0.0.1:8765 ws://127.0.0.1:1420 ws://localhost:1420 ws://127.0.0.1:1421 ws://localhost:1421"
        }
    },
    "bundle": {
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
