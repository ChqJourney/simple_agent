{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "tauri_agent",
    "version":  "0.1.0",
    "identifier":  "photonee",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "tauri_agent",
                                    "width":  800,
                                    "height":  600
                                }
                            ],
                "security":  {
                                 "csp":  "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:8765 ws://127.0.0.1:8765 http://localhost:8765 ws://localhost:8765"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "msi",
                   "externalBin":  [
                                       "binaries/python_backend"
                                   ],
                   "resources":  [
                                     "resources/runtimes/python",
                                     "resources/runtimes/node"
                                 ],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ]
               }
}
